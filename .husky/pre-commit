staged=$(git diff --cached --name-only --diff-filter=ACMR)

# `|| true` matters: husky runs this with `sh -e`, and grep exits 1 when it
# finds nothing (the normal, good case) — without `|| true` that would abort
# the whole script under errexit before the check below ever runs.
forbidden=$(echo "$staged" | grep -E '\.docx?$|^\.claude/|^документи/|(^|/)node_modules/|\.env$|\.env\.local$|backend/prisma/dev\.db$' || true)

if [ -n "$forbidden" ]; then
  echo ""
  echo "COMMIT BLOCKED: staged files that must never be committed:"
  echo "$forbidden" | sed 's/^/  /'
  echo ""
  echo "Unstage with: git restore --staged <file>"
  echo ""
  exit 1
fi
