DATABASE_URL="file:./dev.db"

# Required — signs login tokens. Generate your own with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Optional — enables the "player stats" widget (click a player in a team roster).
# CS2: free API key from https://developers.faceit.com (App Studio → new app →
#      "Server-side" key). Players link their FACEIT nickname/profile URL.
FACEIT_API_KEY=

# Valorant: free key from HenrikDev's Discord — see
#      https://docs.henrikdev.xyz/general/auth for how to request one.
#      Unofficial/community API (no official Riot public API exists) — can
#      break or rate-limit without notice. Players link Riot ID "Name#Tag".
VALORANT_API_KEY=

# Dota 2 has no external integration — Valve hides numeric MMR from the API,
# so the roster's MMR field is filled in manually instead.
