// Prisma schema for the tournament platform (Week 2).
// Provider: SQLite for development (file:./dev.db). Models are PostgreSQL-compatible.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Self-registration allowed (role always "user" on signup); "admin" promotes
// accounts to "organizer" (same create/edit/delete rights over teams,
// tournaments and match scores as "admin", minus account management and
// rarityOverride) or "admin" itself via /api/admin/users.
model User {
  id            Int      @id @default(autoincrement())
  username      String   @unique
  usernameLower String   @unique // username.toLowerCase(), enforces case-insensitive uniqueness (SQLite has no Prisma `mode: "insensitive"`)
  passwordHash  String
  role          String // "admin" | "organizer" | "user"
  bio           String?
  avatar        String? // base64 dataURL, same convention as Team.logo
  createdAt     DateTime @default(now())
}

model Team {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  discipline  String // "CS2" | "Dota 2" | "Valorant"
  logo        String?
  winrate     String?
  streak      String?
  tournaments Int      @default(0)
  best        String?
  rarityOverride String? // "Common" | "Rare" | "Epic" | "Legendary" | null (null = auto from best/tournaments)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  players         Player[]
  tournamentTeams TournamentTeam[]
  ratingHistory   RatingHistory[]
}

model Player {
  id           Int     @id @default(autoincrement())
  teamId       Int
  nick         String
  role         String
  rank         String // stored as text: "2510" for CS2/Dota, "Immortal" for Valorant
  isSubstitute Boolean @default(false)

  // Optional link to an external profile (FACEIT nickname/URL for CS2, Riot
  // ID "Name#Tag" for Valorant — no integration for Dota 2, see rank above)
  // used to fetch live stats. externalStats/externalStatsAt cache the last
  // successful fetch so the widget doesn't hit the third-party API on every
  // open.
  externalRef       String?
  externalStats     String? // JSON-stringified stats payload
  externalStatsAt   DateTime?

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

model Tournament {
  id          Int      @id @default(autoincrement())
  name        String
  discipline  String
  bracketType String // "single" | "double"
  matchFormat Int // 1 | 3 | 5 (best-of)
  status      String   @default("draft")
  date        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  teams   TournamentTeam[]
  matches Match[]
}

model TournamentTeam {
  id           Int @id @default(autoincrement())
  tournamentId Int
  teamId       Int
  seed         Int

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team       Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, teamId])
}

model Match {
  id           Int    @id @default(autoincrement())
  tournamentId Int
  round        Int
  position     Int
  teamAId      Int?
  teamBId      Int?
  scoreA       Int?
  scoreB       Int?
  status       String @default("pending")
  // "winners" | "losers" | "final" — always "winners" for bracketType "single".
  // Round numbers are local to each bracket (see docs/03-double-elimination-spec.md).
  bracket      String @default("winners")

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
}

model RatingHistory {
  id           Int      @id @default(autoincrement())
  teamId       Int
  matchId      Int?
  ratingBefore Int
  ratingAfter  Int
  createdAt    DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
}
